rules_version = '2';

// colorlog Storage セキュリティルール（SPEC §13.3）
//
// 制約: Storage ルールは Firestore を読めない（v2 に firestore.get 相当は無い）。
// そのためメンバー限定 read は Storage 単体では実現できない。
// read は「認証済みなら可」に倒す。画像 URL は post（メンバーしか read できない）経由で
// しか配られないため、URL を知らない非メンバーは実質到達できない（厳格 read は別Issue）。
service firebase.storage {
  match /b/{bucket}/o {
    // trips/{tripId}/{uid}/{postId}: 投稿画像。
    match /trips/{tripId}/{uid}/{postId} {
      allow read: if request.auth != null;
      // write は本人パス（{uid} == auth.uid）・1.5MiB 未満・image/jpeg のみ。
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 1.5 * 1024 * 1024
        && request.resource.contentType == 'image/jpeg';
    }
  }
}
